<launch>
<let name="urdf_path" value="$(find-pkg-share ackerman_bot)/urdf/ack.urdf.xacro"/>
<let name="gazebo_bridge_path" value="$(find-pkg-share ackerman_bot)/config/gazebo_bridge.yaml"/>
<let name="rviz_config_path" value="$(find-pkg-share ackerman_bot)/rviz/rviz_robot.rviz"/>
<let name="gazebo_world_path" value="$(find-pkg-share ackerman_bot)/worlds/shapes.sdf"/>
<node pkg="robot_state_publisher" exec="robot_state_publisher">
<param name="robot_description" value="$(command 'xacro $(var urdf_path)')"/>
</node>
<include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py">
<arg name="gz_args" value="$(var gazebo_world_path) -r"/>
</include>
<node pkg="ros_gz_sim" exec="create" args="-topic robot_description"/>
<node pkg="ros_gz_bridge" exec="parameter_bridge">
<param name="config_file" value="$(var gazebo_bridge_path)"/>
</node>
<node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)"/>
<node pkg="ackerman_bot" exec="vision.py" name="vision_node" output="screen"
        launch-prefix="bash -c 'sleep 5; $0 $@'"/>

    <node pkg="ackerman_bot" exec="control_node.py" name="control_node" output="screen"
        launch-prefix="bash -c 'sleep 6; $0 $@'"/>
</launch>